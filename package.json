{
  "name": "claro",
  "version": "1.0.0",
  "description": "CLARO - AI-powered learning assistant with 3-tier pipeline",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite build --watch\" \"env -u ELECTRON_RUN_AS_NODE electron .\"",
    "build": "tsc -p tsconfig.json && vite build",
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "build:electron": "electron-builder",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "electron",
    "react",
    "ai",
    "learning"
  ],
  "author": "CLARO Team",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.1",
    "electron-store": "^8.2.0",
    "openai": "^4.78.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "extends": "./electron-builder.yml"
  }
}
